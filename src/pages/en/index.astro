---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { navItems } from "../../data/i18n";

const title = "Víctor Cazorla Fernández — IT Management, Environmental Management and Professional Ethics";
const description = "IT management · Environmental management · Professional ethics";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  navItems={navItems.en}
>
  <section id="about-me">
    <h2>About me</h2>
    <h3 style="margin-top:0;"><strong>Víctor Cazorla Fernández</strong></h3>
    <p>
      Víctor Cazorla Fernández is an environmental scientist, researcher, and head of technology operations in international environments. His professional and academic activity focuses on environmental sciences, the philosophy of law, and the management of technology organizations.
    </p>
    <p>
      He is president of the Ethics and Deontology Committee of the Official Association of Environmental Scientists of Catalonia, an expert witness for the Department of Justice and Democratic Quality of the Generalitat de Catalunya in environmental matters, a collaborating lecturer at the Official Association of Environmental Scientists of Catalonia, and a member of the AQUA Pool of Experts (Agency for University Quality, Andorra), where he participates in the external evaluation of university degrees in Environmental Science and Earth Sciences.
    </p>
    <p>
      He is a published author in Scopus- and Web of Science-indexed scientific journals in the fields of legal philosophy, normative logic, administrative law, and various biological science specialties. He conducts his research activity with university and professional association affiliation.
    </p>
    <p>
      His professional activity focuses on operations management and service governance in technology organizations. He has led specialized teams in cloud and on-premises architecture and engineering, as well as cybersecurity, and has managed large enterprise accounts.
    </p>
    <p>
      He holds higher education qualifications at MECES 3 (EQF 7) level. The complete list of degrees and specialization studies is available in the Training section.
    </p>

    <div
      style="
        margin: 3rem 0;
        padding: 1.4rem 1.6rem;
        max-width: 680px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 14px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.04),
          rgba(255, 255, 255, 0.015)
        );
      "
    >
      <a
        href="https://www.linkedin.com/in/victorcazorla-f/"
        target="_blank"
        rel="noopener noreferrer"
        style="
          text-decoration: none;
          color: inherit;
        "
      >
        <p
          style="
            margin: 0;
            font-size: 0.95rem;
            line-height: 1.55;
            color: rgba(255, 255, 255, 0.85);
          "
        >
          You can follow my professional activity and publications on LinkedIn.
        </p>
      </a>
    </div>

    <hr class="page-note-separator" aria-hidden="true" />
    <footer class="page-note" style="max-width:720px;">
      <div style="
        padding: 1rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius:10px;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
      ">
        <p style="margin:0; font-size:0.92rem; line-height:1.5; opacity:0.9;">
          <em>
            This website is not meant to replace a conventional professional presentation or provide a curriculum summary; the <em>what</em> of his career can be found on LinkedIn. Here it is deliberately placed on the <em>how</em>: the criteria from which he interprets his practice, the conceptual frameworks that guide his decisions and the questions that shape his work as a professional and researcher.
          </em>
        </p>
      </div>
    </footer>

  </section>
</BaseLayout>
