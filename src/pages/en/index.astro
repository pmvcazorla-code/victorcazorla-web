---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { navItems } from "../../data/i18n";

const title = "Víctor Cazorla Fernández — IT Management, Environmental Management and Professional Ethics";
const description = "IT management · Environmental management · Professional ethics";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  navItems={navItems.en}
>
  <h1>IT Management, Environmental Management and Professional Ethics</h1>
  <section id="about-me">
    <div
      style="
        margin: 2rem 0;
        display: flex;
        justify-content: center;
      "
    >
      <img
        src="/images/portada.jpg"
        alt="Cover"
        style="
          width: 100%;
          max-width: 700px;
          height: auto;
          border-radius: 8px;
          box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
        "
      />
    </div>
    <h2>About me</h2>
    <p>
      Professional in technology and environmental management, researcher in natural sciences and legal philosophy, environmental expert witness, and president of the Ethics and Deontology Committee at COAMB.
    </p>
    <p>
      This space was created to share and contribute value from my professional journey. Here I collect my own reflections, published articles, media interventions, and materials linked to my professional activity. Therefore, this site is not intended to replace a conventional professional presentation or provide a curriculum summary; the <em>what</em> of my career can be found on my LinkedIn. This website, instead, is deliberately positioned on the <em>how</em>: the way I think about problems, the criteria from which I interpret my practice, and the conceptual frameworks that guide my decisions.
    </p>

    <div
      style="
        margin: 3rem 0;
        padding: 1.4rem 1.6rem;
        max-width: 680px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 14px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.04),
          rgba(255, 255, 255, 0.015)
        );
      "
    >
      <a
        href="https://www.linkedin.com/in/victorcazorla-f/"
        target="_blank"
        rel="noopener noreferrer"
        style="
          display: flex;
          align-items: center;
          gap: 1.4rem;
          text-decoration: none;
          color: inherit;
        "
      >
        <img
          src="/img/linkedin_face.jpg"
          alt="Víctor Cazorla Fernández"
          style="
            width: 160px;
            height: 160px;
            max-width: 160px;
            max-height: 160px;
            object-fit: cover;
            border-radius: 50%;
            flex-shrink: 0;
            display: block;
            border: 1px solid rgba(212, 175, 55, 0.6);
          "
        />

        <div>
          <p
            style="
              margin: 0;
              font-size: 0.95rem;
              line-height: 1.55;
              color: rgba(255, 255, 255, 0.85);
            "
          >
            You can follow my professional activity and publications on LinkedIn.
          </p>
        </div>
      </a>
    </div>

    <div
      aria-hidden="true"
      style="
        margin: 3.8rem 0 3.2rem;
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          rgba(255, 255, 255, 0.18),
          transparent
        );
      "
    ></div>

  </section>
</BaseLayout>
