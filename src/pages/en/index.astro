---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { navItems } from "../../data/i18n";

const title = "Víctor Cazorla Fernández — IT Management, Environmental Management and Professional Ethics";
const description = "IT management · Environmental management · Professional ethics";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  navItems={navItems.en}
>
  <h1>IT Management, Environmental Management and Professional Ethics</h1>
  <section id="about-me">
    <h2>About me</h2>
    <p>
      Víctor Cazorla Fernández is an executive in information technology and a researcher in natural sciences, legal theory and normative logic. He is also an expert witness, lecturer and president of the Ethics and Deontology Committee at COAMB.
    </p>
    <p>
      This website is not meant to replace a conventional professional presentation or provide a curriculum summary; the <em>what</em> of his career can be found on LinkedIn. Here it is deliberately placed on the <em>how</em>: the criteria from which he interprets his practice, the conceptual frameworks that guide his decisions and the questions that shape his work as a professional, researcher and active member of the community.
    </p>

    <div
      style="
        margin: 3rem 0;
        padding: 1.4rem 1.6rem;
        max-width: 680px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 14px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.04),
          rgba(255, 255, 255, 0.015)
        );
      "
    >
      <a
        href="https://www.linkedin.com/in/victorcazorla-f/"
        target="_blank"
        rel="noopener noreferrer"
        style="
          text-decoration: none;
          color: inherit;
        "
      >
        <p
          style="
            margin: 0;
            font-size: 0.95rem;
            line-height: 1.55;
            color: rgba(255, 255, 255, 0.85);
          "
        >
          You can follow my professional activity and publications on LinkedIn.
        </p>
      </a>
    </div>

    <div
      aria-hidden="true"
      style="
        margin: 3.8rem 0 3.2rem;
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          rgba(255, 255, 255, 0.18),
          transparent
        );
      "
    ></div>

  </section>
</BaseLayout>
