---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { navItems } from "../../data/i18n";

const title = "Formation académique";
const credentials = [
  "Máster en Dirección Internacional Contable y Financiera",
  "Máster en Dirección y Gestión de Tecnologías de la Información",
  "Máster en Dirección de Operaciones, Calidad y Proyectos",
  "Máster en Logística, Transporte, Cadena de Suministro y Estrategia Operativa",
  "Postgrado en Administración y Dirección de Empresas",
  "Postgrado en Bolsa y Mercados Financieros",
  "Postgrado en Lean Management y Sistemas de Calidad ISO 9001",
  "Postgrado en Sostenibilidad, Seguridad e Innovación Tecnológica",
  "Máster en Gestión del Medioambiente y Economía de la Energía",
  "Postgrado en Derecho Medioambiental",
  "Postgrado en Gestión de Proyectos",
  "Postgrado en Auditoría Ambiental",
  "Postgrado en Sistemas Energéticos y Gestión de Residuos",
  "Postgrado en Entomología",
  "Postgrado en Virología",
  "Postgrado en Estadística",
  "Grado en Ciencias Ambientales",
  "Máster de Investigación en Filosofía (especialidad en Lógica Aplicada a la Teoría del Derecho)",
  "Formación Profesional en la rama Sanitaria",
  "Formación Profesional en Sistemas Informáticos"
];
---

<BaseLayout title={title} image="/images/og/formacion.svg" imageAlt="Formation — Víctor Cazorla Fernández" lang="fr" navItems={navItems.fr}>
  <main class="container narrow">

    <h1>Formation académique</h1>

    <section class="page-header">
      <h2>La formation comme <em>conséquence</em></h2>
    </section>

    <section class="page-content">
      <header class="page-intro">
        <p>
          <em>Il existe une manière d'être au monde qui ne disparaît pas avec le temps ; celle de celui qui persévère dans la question même lorsque les réponses semblent acquises. Cette curiosité, plus proche du geste enfantin de démonter ce qui fonctionne que de la certitude de l'expert qui le tient pour acquis, conduit à traverser les disciplines, à habiter des langages différents et à se méfier des certitudes prématurées. La formation, par conséquent, n'est pas l'objet lui-même du savoir, mais l'effet inévitable d'un regard qui refuse de s'habituer à voir le monde tel qu'il lui est donné.</em>
        </p>
      </header>

      <section id="formation-direction" class="formation-block" aria-labelledby="h-direction">
        <h2 id="h-direction">Formation universitaire en gestion technologique, d'entreprise et financière</h2>
        <ul>
          <li><span class="degree">Master en direction internationale comptable et financière</span></li>
          <li><span class="degree">Master en gestion des technologies de l'information</span></li>
          <li><span class="degree">Master en direction des opérations, qualité et projets</span></li>
          <li><span class="degree">Master en logistique, transport, chaîne d'approvisionnement et stratégie opérationnelle</span></li>
          <li><span class="degree">Master en prévention des risques professionnels</span></li>
          <li><span class="degree">Postgrade en administration et direction des entreprises</span></li>
          <li><span class="degree">Postgrade en bourse et marchés financiers</span></li>
          <li><span class="degree">Postgrade en Lean Management et systèmes de qualité ISO 9001</span></li>
          <li><span class="degree">Postgrade en durabilité, sécurité et innovation technologique</span></li>
          <li><span class="degree">Formation professionnelle en systèmes informatiques</span></li>
        </ul>
      </section>

      <section class="formation-block">
        <h2 id="h-environnement">Formation universitaire en sciences de l'environnement</h2>
      </section>
      <section id="formation-environnement" class="formation-block" aria-labelledby="h-environnement">
        <ul>
          <li><span class="degree">Master en gestion de l'environnement et économie de l'énergie</span></li>
          <li><span class="degree">Postgrade en droit de l'environnement</span></li>
          <li><span class="degree">Postgrade en gestion de projets</span></li>
          <li><span class="degree">Postgrade en audit environnemental</span></li>
          <li><span class="degree">Postgrade en systèmes énergétiques et gestion des déchets</span></li>
          <li><span class="degree">Postgrade en entomologie</span></li>
          <li><span class="degree">Postgrade en virologie</span></li>
          <li><span class="degree">Postgrade en statistique</span></li>
          <li><span class="degree">Licence en sciences de l'environnement</span></li>
        </ul>
      </section>

      <section id="formation-humanites" class="formation-block" aria-labelledby="h-humanites">
        <h2 id="h-humanites">Formation universitaire en sciences humaines</h2>
        <ul>
          <li><span class="degree">Master de recherche en philosophie</span></li>
        </ul>
      </section>

      <section id="formation-sante" class="formation-block" aria-labelledby="h-sante">
        <h2 id="h-sante">Formation universitaire en sciences de la santé</h2>
        <ul>
          <li><span class="degree">Postgrade en psychopathologie</span></li>
          <li><span class="degree">Formation professionnelle - branche santé</span></li>
        </ul>
      </section>

      <hr class="page-note-separator" aria-hidden="true" />
      <footer class="page-note">
        <p>
          <em>Toutes les formations de troisième cycle mentionnées correspondent à des diplômes universitaires accrédités, dispensés par des universités espagnoles — dont l'UNED, l'UNIR et l'URJC — conformément aux critères de qualité et de reconnaissance établis par
          <a href="https://www.aneca.es" target="_blank" rel="noopener noreferrer">ANECA</a>
          et
          <a href="https://www.crue.org" target="_blank" rel="noopener noreferrer">CRUE</a>,
          incluant des diplômes d'expert universitaire, des masters universitaires et des masters de formation continue.</em>
        </p>
      </footer>

    </section>
  </main>
</BaseLayout>
