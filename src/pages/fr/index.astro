---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { navItems } from "../../data/i18n";

const title = "Víctor Cazorla Fernández — Gestion des TI, gestion environnementale et éthique professionnelle";
const description = "Gestion des TI · Gestion environnementale · Éthique professionnelle";
---

<BaseLayout title={title} description={description} lang="fr" navItems={navItems.fr}>
  <h1>Gestion des TI, gestion environnementale et éthique professionnelle</h1>
  <section id="a-propos">
    <div
      style="
        margin: 2rem 0;
        display: flex;
        justify-content: center;
      "
    >
      <img
        src="/images/portada.jpg"
        alt="Couverture"
        style="
          width: 100%;
          max-width: 700px;
          height: auto;
          border-radius: 8px;
          box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
        "
      />
    </div>

    <h2>À propos de moi</h2>
    <p>
      Víctor Cazorla Fernández est dirigeant et consultant en technologies de l'information, gestionnaire environnemental, chercheur en sciences naturelles et philosophie du droit, expert judiciaire en environnement et président du Comité d'Éthique et de Déontologie du COAMB.
    </p>
    <p>
      Son travail réunit trois facettes complémentaires présentes sur ce site : la gestion IT et la transformation numérique responsable, la gestion environnementale et la protection des écosystèmes, et la réflexion éthique sur la pratique professionnelle. Sur ce site, il rassemble des réflexions, des articles, des interventions dans les médias et des ressources qui montrent comment ces domaines convergent dans sa manière d'aborder les problèmes complexes.
    </p>
    <p>
      Ce site n'a pas pour vocation de remplacer une présentation professionnelle conventionnelle ni d'offrir un résumé de CV ; le <em>quoi</em> de son parcours peut être consulté sur LinkedIn. Il se situe ici délibérément sur le <em>comment</em> : les critères à partir desquels il interprète sa pratique, les cadres conceptuels qui guident ses décisions et les questions qui orientent son action en tant que professionnel, chercheur et membre actif de la communauté.
    </p>

    <div
      style="
        margin: 3rem 0;
        padding: 1.4rem 1.6rem;
        max-width: 680px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 14px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.04),
          rgba(255, 255, 255, 0.015)
        );
      "
    >
      <a
        href="https://www.linkedin.com/in/victorcazorla-f/"
        target="_blank"
        rel="noopener noreferrer"
        style="
          display: flex;
          align-items: center;
          gap: 1.4rem;
          text-decoration: none;
          color: inherit;
        "
      >
        <img
          src="/img/linkedin_face.jpg"
          alt="Víctor Cazorla Fernández"
          style="
            width: 160px;
            height: 160px;
            max-width: 160px;
            max-height: 160px;
            object-fit: cover;
            border-radius: 50%;
            flex-shrink: 0;
            display: block;
            border: 1px solid rgba(212, 175, 55, 0.6);
          "
        />

        <div>
          <p
            style="
              margin: 0;
              font-size: 0.95rem;
              line-height: 1.55;
              color: rgba(255, 255, 255, 0.85);
            "
          >
            Vous pouvez suivre mon activité professionnelle et mes publications sur LinkedIn.
          </p>
        </div>
      </a>
    </div>

    <div
      aria-hidden="true"
      style="
        margin: 3.8rem 0 3.2rem;
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          rgba(255, 255, 255, 0.18),
          transparent
        );
      "
    ></div>
  </section>
</BaseLayout>
