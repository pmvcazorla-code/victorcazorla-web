---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { navItems } from "../../data/i18n";

const title = "Víctor Cazorla Fernández — Direcció IT, Gestió Ambiental i Ètica Professional";
const description = "Direcció IT · Gestió Ambiental · Ètica professional";
---

<BaseLayout title={title} description={description} lang="ca" navItems={navItems.ca}>
  <h1>Direcció IT, Gestió Ambiental i Ètica Professional</h1>
  <section id="sobre-mi">
    <h2>Sobre mi</h2>
    <p>
      Víctor Cazorla Fernández és directiu en tecnologia de la informació i investigador en ciències naturals i jurídiques. També és perit judicial, docent i president del Comitè d'Ètica i Deontologia del COAMB.
    </p>
    <p>
      Des de juny de 2026 formo part de la Borsa d'experts d'AQUA (Agència de Qualitat Universitària, Andorra), aportant experiència en avaluació externa i garantia de la qualitat formativa.
    </p>
    <p>
      Aquest web no pretén substituir una presentació professional convencional ni oferir una síntesi curricular; el <em>què</em> de la seva trajectòria es pot consultar a LinkedIn. Aquí se situa deliberadament en el pla del <em>com</em>: els criteris des dels quals interpreta la seva pràctica, els marcs conceptuals que guien les seves decisions i les preguntes que orienten la seva actuació com a professional, investigador i membre actiu de la comunitat.
    </p>

    <div
      style="
        margin: 3rem 0;
        padding: 1.4rem 1.6rem;
        max-width: 680px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 14px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.04),
          rgba(255, 255, 255, 0.015)
        );
      "
    >
      <a
        href="https://www.linkedin.com/in/victorcazorla-f/"
        target="_blank"
        rel="noopener noreferrer"
        style="
          text-decoration: none;
          color: inherit;
        "
      >
        <p
          style="
            margin: 0;
            font-size: 0.95rem;
            line-height: 1.55;
            color: rgba(255, 255, 255, 0.85);
          "
        >
          Pots seguir la meva activitat professional i les meves publicacions a LinkedIn.
        </p>
      </a>
    </div>

    <div
      aria-hidden="true"
      style="
        margin: 3.8rem 0 3.2rem;
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          rgba(255, 255, 255, 0.18),
          transparent
        );
      "
    ></div>
  </section>
</BaseLayout>
