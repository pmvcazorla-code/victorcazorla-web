---
type NavItem = {
  href: string;
  label: string;
};

import { languages, routes, type LanguageOption } from "../data/i18n";

type BaseLayoutProps = {
  title?: string;
  description?: string;
  image?: string | null;
  imageAlt?: string;
  lang?: "es" | "en" | "fr" | "ca";
  navItems?: NavItem[];
};

const {
  title = "Víctor Cazorla Fernández",
  description = "Dirección IT · Gestión Ambiental · Ética profesional",
  image = null,
  imageAlt = "",
  lang = "es",
  navItems = [],
} = Astro.props as BaseLayoutProps;

const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.endsWith("/") && currentPath !== "/" ? currentPath.slice(0, -1) : currentPath;
const currentRoute = routes.find((route) =>
  Object.values(route.slugs).includes(normalizedPath)
) ?? routes[0];

const languageHref = (code: "es" | "en" | "fr" | "ca") => currentRoute.slugs[code];
const siteUrl = typeof Astro.site === "string" ? Astro.site.replace(/\/$/, "") : Astro.url.origin;
const localeMap = {
  es: "es_ES",
  en: "en_US",
  fr: "fr_FR",
  ca: "ca_ES",
};
const fullUrl = (path: string) => `${siteUrl}${path}`;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={localeMap[lang]} />
    <meta property="og:url" content={fullUrl(currentPath)} />
    <link rel="canonical" href={fullUrl(currentPath)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#070b14" />
    <link rel="alternate" hrefLang="es" href={fullUrl(currentRoute.slugs.es)} />
    <link rel="alternate" hrefLang="en" href={fullUrl(currentRoute.slugs.en)} />
    <link rel="alternate" hrefLang="fr" href={fullUrl(currentRoute.slugs.fr)} />
    <link rel="alternate" hrefLang="ca" href={fullUrl(currentRoute.slugs.ca)} />
    <link rel="alternate" hrefLang="x-default" href={fullUrl(currentRoute.slugs.es)} />
    {image ? <meta property="og:image" content={image} /> : null}
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Víctor Cazorla Fernández",
      url: siteUrl,
      email: "info@victorcazorla.es",
      image: `${siteUrl}/img/linkedin_face.jpg`,
      jobTitle: "IT Management · Environmental Science · Professional Ethics",
      worksFor: {
        "@type": "Organization",
        name: "Independent Professional",
      },
      sameAs: [
        "https://www.linkedin.com/in/victorcazorla-f/",
        "https://orcid.org/0009-0009-7976-9691",
      ],
      knowsAbout: [
        "IT Management",
        "Environmental Science",
        "Professional Ethics",
        "Cloud Architecture",
        "Digital Transformation",
      ],
    })} />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg-main: #070b14;
        --bg-header: rgba(7, 11, 20, 0.88);
        --text-main: #e6e9ef;
        --text-muted: #b6bcc8;
        --accent: #8fb3ff;
        --accent-soft: rgba(143, 179, 255, 0.15);
        --border-soft: rgba(255, 255, 255, 0.08);
        --accent-gold: #d4af37;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, sans-serif;
        background: radial-gradient(
            1200px 600px at 50% -200px,
            #121a2f 0%,
            transparent 70%
          ),
          var(--bg-main);
        color: var(--text-main);
        line-height: 1.75;
      }

      /* ===== HEADER ===== */
      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: linear-gradient(
          to bottom,
          rgba(18, 26, 47, 0.92),
          rgba(7, 11, 20, 0.88)
        );
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(212, 175, 55, 0.25);
      }

      .header-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.1rem 1.5rem 1.2rem;
        text-align: center;
      }

      header h1 {
        font-family: "Playfair Display", serif;
        font-size: clamp(2.1rem, 4vw, 3.4rem);
        margin: 0;
        letter-spacing: 0.02em;
      }

      .subtitle {
        margin-top: 0.4rem;
        font-size: 0.8rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      nav {
        margin-top: 1rem;
        display: flex;
        justify-content: center;
        gap: 0.6rem;
        flex-wrap: nowrap;
      }

      nav a {
        padding: 0.45rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--border-soft);
        color: var(--text-main);
        text-decoration: none;
        font-size: 0.88rem;
        background: rgba(255, 255, 255, 0.03);
        white-space: nowrap;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
      }

      .lang-switch-group {
        margin-top: 1rem;
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .lang-switch {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.55rem;
        padding: 0.45rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--border-soft);
        color: var(--accent);
        text-decoration: none;
        font-size: 0.82rem;
        transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
      }

      .lang-switch.active {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.12);
      }

      .lang-switch .flag-icon {
        display: inline-flex;
        width: 1.1rem;
        height: 0.85rem;
        min-width: 1.1rem;
      }

      .lang-switch svg {
        width: 100%;
        height: auto;
        display: block;
      }

      .lang-switch:hover {
        border-color: var(--accent-gold);
        background: rgba(212, 175, 55, 0.08);
        transform: translateY(-1px);
      }

      nav a:hover {
        border-color: var(--accent-gold);
        background: rgba(212, 175, 55, 0.1);
        transform: translateY(-2px);
      }

      nav a:focus {
        outline: 2px solid var(--accent-gold);
        outline-offset: 2px;
      }

      nav a.active {
        border-color: var(--accent-gold);
        background: linear-gradient(
          145deg,
          rgba(212, 175, 55, 0.18),
          rgba(212, 175, 55, 0.05)
        );
        box-shadow:
          0 4px 18px rgba(212, 175, 55, 0.25),
          inset 0 0 0 1px rgba(212, 175, 55, 0.35);
      }

      /* ===== MAIN ===== */
      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 3.2rem 1.6rem 5.5rem;
      }

      h2 {
        font-family: "Playfair Display", serif;
        font-size: 2rem;
        margin-top: 3rem;
        margin-bottom: 1.2rem;
        line-height: 1.2;
        letter-spacing: -0.01em;
      }

      h1 {
        letter-spacing: -0.01em;
        line-height: 1.1;
      }

      p {
        margin: 0 0 1.6rem;
        line-height: 1.8;
      }

      .editorial-text p {
        margin-bottom: 2.2rem;
      }

      footer {
        border-top: 1px solid var(--border-soft);
        text-align: center;
        padding: 2.5rem 1rem;
        font-size: 0.85rem;
        color: var(--text-muted);
        opacity: 0.7;
        transition: opacity 0.3s ease;
      }

      footer:hover {
        opacity: 1;
      }

      /* ===== CARD/GRID OPTIMIZATION ===== */
      a[style*="display: flex; align-items: center"][style*="padding: 1.2rem"] {
        transition: all 0.25s ease;
      }

      a[style*="display: flex; align-items: center"][style*="padding: 1.2rem"]:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        border-color: rgba(212, 175, 55, 0.4) !important;
        transform: translateY(-2px);
      }

      /* Responsive card padding */
      @media (max-width: 480px) {
        a[style*="display: flex; align-items: center"][style*="padding: 1.2rem"] {
          padding: 0.9rem !important;
          gap: 0.8rem !important;
        }

        a[style*="display: flex; align-items: center"][style*="padding: 1.2rem"] img {
          width: 40px !important;
          height: 40px !important;
        }

        a[style*="display: flex; align-items: center"][style*="padding: 1.2rem"] p {
          font-size: 0.8rem !important;
        }
      }

      /* ===== TABLET ===== */
      @media (max-width: 768px) {
        .header-inner {
          padding: 0.65rem 0.9rem 0.95rem;
        }

        header h1 {
          font-size: 1.6rem;
        }

        .subtitle {
          font-size: 0.72rem;
          letter-spacing: 0.16em;
          margin-top: 0.25rem;
        }

        nav {
          margin-top: 0.6rem;
          justify-content: flex-start;
          flex-wrap: nowrap;
          gap: 0.3rem;
          overflow-x: auto;
          padding-bottom: 0.2rem;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }

        nav a {
          font-size: 0.78rem;
          padding: 0.28rem 0.7rem;
          white-space: nowrap;
          flex: 0 0 auto;
        }

        nav::-webkit-scrollbar {
          display: none;
        }

        .lang-switch-group {
          margin-top: 0.45rem;
          justify-content: flex-start;
          flex-wrap: nowrap;
          overflow-x: auto;
          gap: 0.35rem;
          padding-bottom: 0.15rem;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }

        .lang-switch-group::-webkit-scrollbar {
          display: none;
        }

        .lang-switch {
          font-size: 0.72rem;
          padding: 0.3rem 0.6rem;
          white-space: nowrap;
          flex: 0 0 auto;
        }

        main {
          padding: 1.75rem 1.2rem 2.5rem;
        }

        main h1 {
          font-family: "Playfair Display", serif;
          font-size: 1.5rem;
          line-height: 1.2;
          margin-top: 1rem;
          margin-bottom: 0.6rem;
          letter-spacing: -0.01em;
        }

        h2 {
          font-size: 1.6rem;
          line-height: 1.3;
          margin-top: 2rem;
          margin-bottom: 1rem;
        }

        h2.section-subtitle {
          font-size: 1.1rem;
          line-height: 1.25;
          margin-top: 1.5rem;
          margin-bottom: 0.8rem;
        }

        p {
          font-size: 0.95rem;
        }

        main > *:first-child {
          margin-top: 0;
        }
      }

      /* ===== MOBILE (480px) ===== */
      @media (max-width: 480px) {
        .header-inner {
          padding: 0.5rem 0.75rem 0.7rem;
        }

        header h1 {
          font-size: 1.2rem;
        }

        .subtitle {
          font-size: 0.58rem;
          letter-spacing: 0.12em;
          margin-top: 0.18rem;
        }

        nav {
          margin-top: 0.45rem;
          gap: 0.2rem;
          flex-wrap: nowrap;
          justify-content: flex-start;
          overflow-x: auto;
          padding-bottom: 0.12rem;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }

        nav a {
          font-size: 0.62rem;
          padding: 0.22rem 0.5rem;
          white-space: nowrap;
          flex: 0 0 auto;
        }

        .lang-switch-group {
          margin-top: 0.35rem;
          gap: 0.2rem;
          justify-content: flex-start;
          flex-wrap: nowrap;
          overflow-x: auto;
          padding-bottom: 0.12rem;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }

        .lang-switch-group::-webkit-scrollbar {
          display: none;
        }

        .lang-switch {
          font-size: 0.68rem;
          padding: 0.22rem 0.48rem;
          gap: 0.3rem;
          white-space: nowrap;
          flex: 0 0 auto;
        }

        .lang-switch .flag-icon {
          width: 0.72rem;
          height: 0.6rem;
          min-width: 0.72rem;
        }

        main {
          padding: 1.1rem 0.85rem 2rem;
        }

        main h1 {
          font-size: 1.1rem;
          line-height: 1.15;
          margin-top: 0.6rem;
          margin-bottom: 0.4rem;
        }

        h2 {
          font-size: 1.3rem;
          line-height: 1.25;
          margin-top: 1.6rem;
          margin-bottom: 0.8rem;
        }

        h2.section-subtitle {
          font-size: 0.95rem;
          margin-top: 1.2rem;
          margin-bottom: 0.6rem;
        }

        p {
          font-size: 0.9rem;
          margin-bottom: 1.2rem;
        }

        footer {
          padding: 1.5rem 0.8rem;
          font-size: 0.75rem;
        }
      }

      /* ===== SMALL MOBILE (< 375px) ===== */
      @media (max-width: 374px) {
        header h1 {
          font-size: 1.1rem;
        }

        .subtitle {
          font-size: 0.55rem;
          letter-spacing: 0.1em;
        }

        nav {
          overflow-x: auto;
          gap: 0.18rem;
          padding-bottom: 0.1rem;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }

        nav::-webkit-scrollbar {
          display: none;
        }

        nav a {
          font-size: 0.6rem;
          padding: 0.2rem 0.45rem;
          white-space: nowrap;
          flex: 0 0 auto;
        }

        main {
          padding: 1rem 0.8rem 2rem;
        }

        main h1 {
          font-size: 1rem;
        }

        h2 {
          font-size: 1.15rem;
          margin-top: 1.4rem;
          margin-bottom: 0.7rem;
        }

        p {
          font-size: 0.85rem;
          margin-bottom: 1rem;
        }
      }
    </style>
    {image ? <link rel="preload" as="image" href={image} /> : null}
  </head>

  <body>
    <header>
      <div class="header-inner">
        <h1>Víctor Cazorla Fernández</h1>
        <div class="subtitle">
          Dirección IT · Gestión Ambiental · Ética profesional
        </div>
        <nav>
          {navItems.map((item) => (
            <a
              href={item.href}
              class={
                item.href === "/"
                  ? currentPath === item.href
                    ? "active"
                    : ""
                  : currentPath === item.href || currentPath.startsWith(item.href + "/")
                  ? "active"
                  : ""
              }
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="lang-switch-group" role="navigation" aria-label="Language selector">
          {languages.map((language: LanguageOption) => (
            <a
              class={"lang-switch" + (language.code === lang ? " active" : "")}
              href={languageHref(language.code)}
              aria-current={language.code === lang ? "page" : undefined}
            >
              <span class="flag-icon" aria-hidden="true">
                {language.code === "es" ? (
                  <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bandera española" focusable="false">
                    <rect width="60" height="30" fill="#AA151B" />
                    <rect y="10" width="60" height="10" fill="#F1BF00" />
                  </svg>
                ) : language.code === "en" ? (
                  <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Union Jack" focusable="false">
                    <rect width="60" height="30" fill="#012169" />
                    <path d="M0 0 L60 30 M60 0 L0 30" stroke="#fff" stroke-width="6" />
                    <path d="M0 0 L60 30 M60 0 L0 30" stroke="#C8102E" stroke-width="4" />
                    <path d="M30 0 L30 30 M0 15 L60 15" stroke="#fff" stroke-width="10" />
                    <path d="M30 0 L30 30 M0 15 L60 15" stroke="#C8102E" stroke-width="6" />
                  </svg>
                ) : language.code === "fr" ? (
                  <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Drapeau français" focusable="false">
                    <rect width="20" height="30" fill="#0055A4" />
                    <rect x="20" width="20" height="30" fill="#FFFFFF" />
                    <rect x="40" width="20" height="30" fill="#EF4135" />
                  </svg>
                ) : (
                  <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Senyera catalana" focusable="false">
                    <rect width="60" height="30" fill="#FFCE00" />
                    <path d="M0 3 H60 M0 10 H60 M0 17 H60 M0 24 H60" stroke="#D52B1E" stroke-width="4" />
                  </svg>
                )}
              </span>
              {language.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      © 2026 · Víctor Cazorla Fernández
    </footer>
  </body>
</html>