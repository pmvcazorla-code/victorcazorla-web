---
type NavItem = {
  href: string;
  label: string;
};

type BaseLayoutProps = {
  title?: string;
  description?: string;
  image?: string | null;
  imageAlt?: string;
  lang?: string;
  navItems?: NavItem[];
  alternateLabel?: string;
};

const {
  title = "Víctor Cazorla Fernández",
  description = "Dirección IT · Gestión Ambiental · Ética profesional",
  image = null,
  imageAlt = "",
  lang = "es",
  navItems = [],
  alternateLabel = "English"
} = Astro.props as BaseLayoutProps;

const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.endsWith("/") && currentPath !== "/" ? currentPath.slice(0, -1) : currentPath;
const alternateHref = (() => {
  if (normalizedPath === "/") return "/en";
  if (normalizedPath === "/en") return "/";
  if (normalizedPath.startsWith("/en/")) return normalizedPath.slice(3);
  return "/en" + normalizedPath;
})();
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentPath} />
    {image ? <meta property="og:image" content={image} /> : null}
    <title>{title}</title>
    <link rel="canonical" href={Astro.url.href} />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg-main: #070b14;
        --bg-header: rgba(7, 11, 20, 0.88);
        --text-main: #e6e9ef;
        --text-muted: #b6bcc8;
        --accent: #8fb3ff;
        --accent-soft: rgba(143, 179, 255, 0.15);
        --border-soft: rgba(255, 255, 255, 0.08);
        --accent-gold: #d4af37;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, sans-serif;
        background: radial-gradient(
            1200px 600px at 50% -200px,
            #121a2f 0%,
            transparent 70%
          ),
          var(--bg-main);
        color: var(--text-main);
        line-height: 1.75;
      }

      /* ===== HEADER ===== */
      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: linear-gradient(
          to bottom,
          rgba(18, 26, 47, 0.92),
          rgba(7, 11, 20, 0.88)
        );
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(212, 175, 55, 0.25);
      }

      .header-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.1rem 1.5rem 1.2rem;
        text-align: center;
      }

      header h1 {
        font-family: "Playfair Display", serif;
        font-size: clamp(2.1rem, 4vw, 3.4rem);
        margin: 0;
        letter-spacing: 0.02em;
      }

      .subtitle {
        margin-top: 0.4rem;
        font-size: 0.8rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      nav {
        margin-top: 1rem;
        display: flex;
        justify-content: center;
        gap: 0.6rem;
        flex-wrap: nowrap;
      }

      nav a {
        padding: 0.45rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--border-soft);
        color: var(--text-main);
        text-decoration: none;
        font-size: 0.88rem;
        background: rgba(255, 255, 255, 0.03);
        white-space: nowrap;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
      }

      .lang-switch {
        margin-top: 1rem;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.55rem;
        padding: 0.45rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--border-soft);
        color: var(--accent);
        text-decoration: none;
        font-size: 0.82rem;
        transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
      }

      .lang-switch .flag-icon {
        display: inline-flex;
        width: 1.1rem;
        height: 0.85rem;
        min-width: 1.1rem;
      }

      .lang-switch svg {
        width: 100%;
        height: auto;
        display: block;
      }

      .lang-switch:hover {
        border-color: var(--accent-gold);
        background: rgba(212, 175, 55, 0.08);
        transform: translateY(-1px);
      }

      nav a:hover {
        border-color: var(--accent-gold);
        background: rgba(212, 175, 55, 0.1);
        transform: translateY(-2px);
      }

      nav a:focus {
        outline: 2px solid var(--accent-gold);
        outline-offset: 2px;
      }

      nav a.active {
        border-color: var(--accent-gold);
        background: linear-gradient(
          145deg,
          rgba(212, 175, 55, 0.18),
          rgba(212, 175, 55, 0.05)
        );
        box-shadow:
          0 4px 18px rgba(212, 175, 55, 0.25),
          inset 0 0 0 1px rgba(212, 175, 55, 0.35);
      }

      /* ===== MAIN ===== */
      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 3.2rem 1.6rem 5.5rem;
      }

      h2 {
        font-family: "Playfair Display", serif;
        font-size: 2rem;
        margin-top: 3rem;
        margin-bottom: 1.2rem;
        line-height: 1.2;
        letter-spacing: -0.01em;
      }

      h1 {
        letter-spacing: -0.01em;
        line-height: 1.1;
      }

      p {
        margin: 0 0 1.6rem;
        line-height: 1.8;
      }

      .editorial-text p {
        margin-bottom: 2.2rem;
      }

      footer {
        border-top: 1px solid var(--border-soft);
        text-align: center;
        padding: 2.5rem 1rem;
        font-size: 0.85rem;
        color: var(--text-muted);
        opacity: 0.7;
        transition: opacity 0.3s ease;
      }

      footer:hover {
        opacity: 1;
      }

      /* ===== MOBILE ===== */
      @media (max-width: 768px) {
        .header-inner {
          padding: 0.5rem 0.8rem 0.6rem;
        }

        header h1 {
          font-size: 1.45rem;
        }

        .subtitle {
          font-size: 0.65rem;
          letter-spacing: 0.14em;
          margin-top: 0.2rem;
        }

        nav {
          margin-top: 0.6rem;
          justify-content: center;
          flex-wrap: wrap;
          row-gap: 0.4rem;
        }

        nav a {
          font-size: 0.72rem;
          padding: 0.28rem 0.65rem;
        }

        main {
          padding: 1.2rem 1.2rem 4rem;
          padding-top: 1.2rem;
        }

        main h1 {
          font-family: "Playfair Display", serif;
          font-size: 1.15rem;
          line-height: 1.15;
          margin-top: 0.8rem;
          margin-bottom: 0.4rem;
          letter-spacing: 0.01em;
          word-break: break-word;
          hyphens: auto;
          padding: 0;
        }

        h2 {
          font-size: 1.45rem;
          line-height: 1.35;
        }

        h2.section-subtitle {
          font-size: 1rem;
          line-height: 1.15;
          margin-top: 1.8rem;
          margin-bottom: 0.8rem;
          word-break: break-word;
          hyphens: auto;
          padding: 0;
        }

        main > *:first-child {
          margin-top: 0;
        }
      }
    </style>
    {image ? <link rel="preload" as="image" href={image} /> : null}
  </head>

  <body>
    <header>
      <div class="header-inner">
        <h1>Víctor Cazorla Fernández</h1>
        <div class="subtitle">
          Dirección IT · Gestión Ambiental · Ética profesional
        </div>
        <nav>
          {navItems.map((item) => (
            <a
              href={item.href}
              class={currentPath === item.href || currentPath.startsWith(item.href + "/") ? "active" : ""}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <a class="lang-switch" href={alternateHref}>
          <span class="flag-icon" aria-hidden="true">
            <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Union Jack" focusable="false">
              <rect width="60" height="30" fill="#012169" />
              <path d="M0 0 L60 30 M60 0 L0 30" stroke="#fff" stroke-width="6" />
              <path d="M0 0 L60 30 M60 0 L0 30" stroke="#C8102E" stroke-width="4" />
              <path d="M30 0 L30 30 M0 15 L60 15" stroke="#fff" stroke-width="10" />
              <path d="M30 0 L30 30 M0 15 L60 15" stroke="#C8102E" stroke-width="6" />
            </svg>
          </span>
          {alternateLabel}
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      © 2026 · Víctor Cazorla Fernández
    </footer>
  </body>
</html>